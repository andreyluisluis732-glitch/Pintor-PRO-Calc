{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Professional painter profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique Firebase Auth ID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "phone": { "type": "string", "description": "User business phone" },
        "cpf": { "type": "string", "description": "Clean CPF (11 digits)" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Estimate": {
      "title": "Paint Estimate",
      "description": "Calculated paint estimate for a client.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner ID" },
        "clientName": { "type": "string" },
        "area": { "type": "number" },
        "totalCost": { "type": "number" },
        "isFromClient": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "area", "totalCost"]
    },
    "Appointment": {
      "title": "Client Appointment",
      "description": "Scheduled visit or service.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Professional ID" },
        "clientName": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "isFromClient": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "clientName", "date", "time"]
    },
    "Settings": {
      "title": "User Settings",
      "description": "Business settings and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "businessPhone": { "type": "string" },
        "laborPricePerM2": { "type": "number" },
        "cpf": { "type": "string" },
        "isPro": { "type": "boolean" },
        "trialStartDate": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid"]
    },
    "CpfUsage": {
      "title": "CPF Usage Tracking",
      "description": "Prevents multiple trial periods.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/estimates/{estimateId}": {
      "schema": "Estimate",
      "description": "Saved estimates"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Client appointments"
    },
    "/settings/{userId}": {
      "schema": "Settings",
      "description": "User business settings"
    },
    "/cpfs/{cpf}": {
      "schema": "CpfUsage",
      "description": "CPF uniqueness registry"
    }
  }
}
