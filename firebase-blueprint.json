{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Estimate": {
      "title": "Estimate",
      "description": "Painting estimate details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "clientName": { "type": "string" },
        "clientPhone": { "type": "string" },
        "propertyType": { "type": "string" },
        "city": { "type": "string" },
        "neighborhood": { "type": "string" },
        "location": { "type": "string" },
        "includePaint": { "type": "boolean" },
        "area": { "type": "number" },
        "productId": { "type": "string" },
        "color": { "type": "string" },
        "coats": { "type": "integer" },
        "pricePerM2": { "type": "number" },
        "totalLiters": { "type": "number" },
        "packageSize": { "type": "string" },
        "packageCount": { "type": "integer" },
        "materialCost": { "type": "number" },
        "laborCost": { "type": "number" },
        "totalCost": { "type": "number" },
        "date": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "uid", "area", "totalCost"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Scheduled appointment details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "clientName": { "type": "string" },
        "clientPhone": { "type": "string" },
        "clientEmail": { "type": "string" },
        "clientAddress": { "type": "string" },
        "notes": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "uid", "clientName", "date", "time"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "estimates/{estimateId}": {
      "schema": "Estimate",
      "description": "Painting estimates"
    },
    "appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Scheduled appointments"
    }
  }
}
